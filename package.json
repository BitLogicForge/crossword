{
  "name": "crossword",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "homepage": "https://bitlogicforge.github.io/crossword",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx}\"",
    "format:check": "prettier --check .",
    "type-check": "tsc -b",
    "preview": "vite preview",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist",
    "deploy:clean": "gh-pages -d dist -c",
    "update": "npm-check-updates -u",
    "update:minor": "npm-check-updates -u --target minor",
    "update:noes": "npx npm-check-updates -u --reject @eslint/js --reject eslint",
    "clean:linux": "rm -rf dist node_modules",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "knip": "knip",
    "git:fix": "git add . && git commit -m 'clean' && git push"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.0.1",
    "@mui/material": "^9.0.1",
    "@reduxjs/toolkit": "^2.12.0",
    "i18next": "^26.2.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^4.0.0",
    "motion": "^12.40.0",
    "react": "^19.2.6",
    "react-country-flag": "^3.1.0",
    "react-dom": "^19.2.6",
    "react-i18next": "^17.0.8",
    "react-redux": "^9.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "gh-pages": "^6.3.0",
    "globals": "^17.6.0",
    "knip": "^6.14.0",
    "npm-check-updates": "^22.2.0",
    "prettier": "^3.8.3",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^8.0.13"
  }
}
